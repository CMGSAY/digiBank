# ============================================================
# .env.production.example
# CONFIGURACIÓN PARA EL DESPLIEGUE EN PRODUCCIÓN DE DIGIBANK MVP
# ============================================================

# --- SERVIDOR ---
NODE_ENV=production
PORT=10000

# --- MYSQL (Ej. Aiven o TiDB Cloud) ---
DB_HOST=tu-host-mysql.aivencloud.com
DB_PORT=25252
DB_USER=avnadmin
DB_PASSWORD=tu-contrasena-mysql
DB_NAME=digibank_mvp
DB_SSL=true

# --- MONGODB ATLAS ---
MONGODB_URI=mongodb+srv://usuario-atlas:contrasena-atlas@cluster0.xxxx.mongodb.net/digibank_foro?retryWrites=true&w=majority

# --- JWT ---
# Genera un token aleatorio seguro (por ejemplo usando: openssl rand -base64 32)
JWT_SECRET=tu_jwt_secreto_robusto_minimo_32_caracteres

# --- CORS / FRONTEND URL ---
# URL final asignada por Vercel para el frontend
FRONTEND_URL=https://digibank-frontend.vercel.app

# --- GOOGLE OAUTH2 ---
# (Opcional, configurar si se usa inicio de sesión con Google)
GOOGLE_CLIENT_ID=tu-google-client-id
GOOGLE_CLIENT_SECRET=tu-google-client-secret
